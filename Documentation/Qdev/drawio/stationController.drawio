        <mxCell id="_mLCww8DbmtVN4fqQYOz-221" value="&lt;div&gt;const toRad = (deg) =&amp;gt; (deg * Math.PI) / 180;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; const dLat = toRad(lat2 - lat1);&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; const dLon = toRad(lon2 - lon1);&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; const a =&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; Math.sin(dLat / 2) * Math.sin(dLat / 2) +&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) *&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; Math.sin(dLon / 2) * Math.sin(dLon / 2);&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; return 6371 * c;&lt;/div&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];" parent="_mLCww8DbmtVN4fqQYOz-220" vertex="1" connectable="0">
