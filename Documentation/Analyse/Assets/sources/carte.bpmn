    <bpmn:startEvent id="Event_user_open_app" name="ouvre l&#39;application mobile">
      <bpmn:outgoing>Flow_c1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Activity_user_open_map" name="ouvre la carte">
      <bpmn:incoming>Flow_c1</bpmn:incoming>
      <bpmn:outgoing>Flow_c2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Activity_user_choose_data" name="choisit les données à afficher sur la carte">
      <bpmn:incoming>Flow_c2</bpmn:incoming>
      <bpmn:outgoing>Flow_c3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_c1" sourceRef="Event_user_open_app" targetRef="Activity_user_open_map" />
    <bpmn:sequenceFlow id="Flow_c2" sourceRef="Activity_user_open_map" targetRef="Activity_user_choose_data" />
    <bpmn:sequenceFlow id="Flow_c3" sourceRef="Activity_user_choose_data" targetRef="Gateway_option" />
    <bpmn:sequenceFlow id="Flow_c4a" name="lignes cyclables" sourceRef="Gateway_option" targetRef="Activity_send_cycle" />
    <bpmn:sequenceFlow id="Flow_c4b" name="parking vélo" sourceRef="Gateway_option" targetRef="Activity_send_parking" />
    <bpmn:sequenceFlow id="Flow_c4c" name="carte touristique" sourceRef="Gateway_option" targetRef="Activity_send_touristic" />
    <bpmn:sequenceFlow id="Flow_c5a" sourceRef="Activity_send_cycle" targetRef="Gateway_after_option" />
    <bpmn:sequenceFlow id="Flow_c5b" sourceRef="Activity_send_parking" targetRef="Gateway_after_option" />
    <bpmn:sequenceFlow id="Flow_c5c" sourceRef="Activity_send_touristic" targetRef="Gateway_after_option" />
    <bpmn:sequenceFlow id="Flow_c9" sourceRef="Event_client_wait" targetRef="Activity_client_receive" />
    <bpmn:sequenceFlow id="Flow_c10" sourceRef="Activity_client_receive" targetRef="Event_client_data" />
    <bpmn:sequenceFlow id="Flow_c11" sourceRef="Event_client_data" targetRef="Gateway_data" />
    <bpmn:sequenceFlow id="Flow_c12_yes" name="oui" sourceRef="Gateway_data" targetRef="Activity_show_data" />
    <bpmn:sequenceFlow id="Flow_c12_no" name="non" sourceRef="Gateway_data" targetRef="Activity_show_error" />
    <bpmn:sequenceFlow id="Flow_c13" sourceRef="Activity_show_data" targetRef="Event_end_ok" />
    <bpmn:sequenceFlow id="Flow_c14" sourceRef="Activity_show_error" targetRef="Event_end_error" />
    <bpmn:sendTask id="Activity_send_touristic" name="demande les données touristiques au Proxy">
      <bpmn:incoming>Flow_c4c</bpmn:incoming>
      <bpmn:outgoing>Flow_c5c</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:sendTask id="Activity_send_parking" name="demande les données des parkings vélo au Proxy">
      <bpmn:incoming>Flow_c4b</bpmn:incoming>
      <bpmn:outgoing>Flow_c5b</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:sendTask id="Activity_send_cycle" name="demande les données des lignes cyclables au Proxy">
      <bpmn:incoming>Flow_c4a</bpmn:incoming>
      <bpmn:outgoing>Flow_c5a</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:parallelGateway id="Gateway_option" name="option choisie ?">
      <bpmn:incoming>Flow_c3</bpmn:incoming>
      <bpmn:outgoing>Flow_c4a</bpmn:outgoing>
      <bpmn:outgoing>Flow_c4b</bpmn:outgoing>
      <bpmn:outgoing>Flow_c4c</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:parallelGateway id="Gateway_after_option">
      <bpmn:incoming>Flow_c5a</bpmn:incoming>
      <bpmn:incoming>Flow_c5b</bpmn:incoming>
      <bpmn:incoming>Flow_c5c</bpmn:incoming>
      <bpmn:outgoing>Flow_1n9ck0t</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:sequenceFlow id="Flow_1n9ck0t" sourceRef="Gateway_after_option" targetRef="Event_0d64qz5" />
    <bpmn:sequenceFlow id="Flow_1em9bb4" sourceRef="Event_0d64qz5" targetRef="Activity_1t9b1wr" />
    <bpmn:task id="Activity_1t9b1wr" name="se met en attente">
      <bpmn:incoming>Flow_1em9bb4</bpmn:incoming>
      <bpmn:outgoing>Flow_1fd0wl3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:scriptTask id="Activity_show_data" name="affiche les données sur la carte pour l&#39;utilisateur">
      <bpmn:incoming>Flow_c12_yes</bpmn:incoming>
      <bpmn:outgoing>Flow_c13</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:endEvent id="Event_end_ok">
      <bpmn:incoming>Flow_c13</bpmn:incoming>
      <bpmn:terminateEventDefinition id="TerminateDef_ok" />
    </bpmn:endEvent>
    <bpmn:scriptTask id="Activity_show_error" name="affiche une erreur">
      <bpmn:incoming>Flow_c12_no</bpmn:incoming>
      <bpmn:outgoing>Flow_c14</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:endEvent id="Event_end_error" name="erreur">
      <bpmn:incoming>Flow_c14</bpmn:incoming>
      <bpmn:errorEventDefinition id="ErrorDef_client" />
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="Gateway_data" name="data ?">
      <bpmn:incoming>Flow_c11</bpmn:incoming>
      <bpmn:outgoing>Flow_c12_yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_c12_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:intermediateCatchEvent id="Event_client_data" name="data">
      <bpmn:incoming>Flow_c10</bpmn:incoming>
      <bpmn:outgoing>Flow_c11</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageDef_client_data" />
    </bpmn:intermediateCatchEvent>
    <bpmn:receiveTask id="Activity_client_receive" name="Reçois une reponse de l&#39;API">
      <bpmn:incoming>Flow_c9</bpmn:incoming>
      <bpmn:outgoing>Flow_c10</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:intermediateCatchEvent id="Event_client_wait" name="attendre data">
      <bpmn:incoming>Flow_1fd0wl3</bpmn:incoming>
      <bpmn:outgoing>Flow_c9</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_client_wait" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="Flow_1fd0wl3" sourceRef="Activity_1t9b1wr" targetRef="Event_client_wait" />
    <bpmn:intermediateThrowEvent id="Event_0d64qz5" name="demande">
      <bpmn:incoming>Flow_1n9ck0t</bpmn:incoming>
      <bpmn:outgoing>Flow_1em9bb4</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_19otkcz" />
    </bpmn:intermediateThrowEvent>
  </bpmn:process>
  <bpmn:process id="Process_Proxy">
    <bpmn:intermediateCatchEvent id="Event_proxy_receive_demande" name="demande">
      <bpmn:outgoing>Flow_p1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_17t69l1" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sendTask id="Activity_proxy_send_api" name="envoie requête à l&#39;API source">
      <bpmn:incoming>Flow_p1</bpmn:incoming>
      <bpmn:outgoing>Flow_p2</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:intermediateThrowEvent id="Event_proxy_send_request" name="requete">
      <bpmn:incoming>Flow_p2</bpmn:incoming>
      <bpmn:outgoing>Flow_p3</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_09lekpz" />
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="Event_proxy_wait" name="attente">
      <bpmn:incoming>Flow_p3</bpmn:incoming>
      <bpmn:outgoing>Flow_p4</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_09nuzl6" />
    </bpmn:intermediateCatchEvent>
    <bpmn:receiveTask id="Activity_proxy_receive_response" name="Reçois une reponse">
      <bpmn:incoming>Flow_p4</bpmn:incoming>
      <bpmn:outgoing>Flow_p5</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:intermediateCatchEvent id="Event_proxy_response" name="response">
      <bpmn:incoming>Flow_p5</bpmn:incoming>
      <bpmn:outgoing>Flow_p6</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1nobbcx" />
    </bpmn:intermediateCatchEvent>
    <bpmn:exclusiveGateway id="Gateway_proxy_response" name="response ?">
      <bpmn:incoming>Flow_p6</bpmn:incoming>
      <bpmn:outgoing>Flow_p7_yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_p7_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:scriptTask id="Activity_proxy_process_data" name="traite les données demandées">
      <bpmn:incoming>Flow_p7_yes</bpmn:incoming>
      <bpmn:outgoing>Flow_p8</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:sequenceFlow id="Flow_p1" sourceRef="Event_proxy_receive_demande" targetRef="Activity_proxy_send_api" />
    <bpmn:sequenceFlow id="Flow_p2" sourceRef="Activity_proxy_send_api" targetRef="Event_proxy_send_request" />
    <bpmn:sequenceFlow id="Flow_p3" sourceRef="Event_proxy_send_request" targetRef="Event_proxy_wait" />
    <bpmn:sequenceFlow id="Flow_p4" sourceRef="Event_proxy_wait" targetRef="Activity_proxy_receive_response" />
    <bpmn:sequenceFlow id="Flow_p5" sourceRef="Activity_proxy_receive_response" targetRef="Event_proxy_response" />
    <bpmn:sequenceFlow id="Flow_p6" sourceRef="Event_proxy_response" targetRef="Gateway_proxy_response" />
    <bpmn:sequenceFlow id="Flow_p7_yes" name="oui" sourceRef="Gateway_proxy_response" targetRef="Activity_proxy_process_data" />
    <bpmn:sequenceFlow id="Flow_p7_no" name="non" sourceRef="Gateway_proxy_response" targetRef="Event_proxy_send_error" />
    <bpmn:sequenceFlow id="Flow_p8" sourceRef="Activity_proxy_process_data" targetRef="Event_proxy_send_data" />
    <bpmn:endEvent id="Event_proxy_send_data" name="data">
      <bpmn:incoming>Flow_p8</bpmn:incoming>
      <bpmn:messageEventDefinition id="MessageEventDefinition_163t2t2" />
    </bpmn:endEvent>
    <bpmn:endEvent id="Event_proxy_send_error" name="erreur">
      <bpmn:incoming>Flow_p7_no</bpmn:incoming>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1fw8foa" />
    </bpmn:endEvent>
  </bpmn:process>
