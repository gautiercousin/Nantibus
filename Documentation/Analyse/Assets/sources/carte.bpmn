    <bpmn:participant id="Participant_1if7md0" name="Base de donnée" processRef="Process_1k69mt3" />
    <bpmn:participant id="Participant_079n6nm" name="API Sources" processRef="Process_127cnym" />
    <bpmn:messageFlow id="Flow_1s81ypf" sourceRef="Event_proxy_send_error" targetRef="Event_client_data" />
    <bpmn:messageFlow id="Flow_1trpjq0" sourceRef="Event_proxy_send_data" targetRef="Event_client_data" />
    <bpmn:messageFlow id="Flow_1ppa70t" sourceRef="Event_proxy_send_request" targetRef="Participant_1if7md0" />
    <bpmn:messageFlow id="Flow_1m60flx" sourceRef="Event_proxy_send_request" targetRef="Participant_079n6nm" />
    <bpmn:messageFlow id="Flow_1gxvdt9" sourceRef="Participant_1if7md0" targetRef="Event_proxy_response" />
