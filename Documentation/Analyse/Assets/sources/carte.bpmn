  </bpmn:collaboration>
  <bpmn:process id="Process_Client">
    <bpmn:laneSet id="LaneSet_Client">
      <bpmn:lane id="Lane_User" name="Utilisateur">
        <bpmn:flowNodeRef>Event_user_open_app</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_user_open_map</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_user_choose_data</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Mobile" name="Application mobile">
