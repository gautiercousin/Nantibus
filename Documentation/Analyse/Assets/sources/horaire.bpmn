    <bpmn:startEvent id="Event_user_open_app" name="ouvre l&#39;application mobile">
      <bpmn:outgoing>Flow_c1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Activity_user_open_schedule_page" name="accède à la page des horaires">
      <bpmn:incoming>Flow_c1</bpmn:incoming>
      <bpmn:outgoing>Flow_c2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Activity_user_search" name="réalise une recherche (parking, station vélo, etc)">
      <bpmn:incoming>Flow_c2</bpmn:incoming>
      <bpmn:outgoing>Flow_c3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_c1" sourceRef="Event_user_open_app" targetRef="Activity_user_open_schedule_page" />
